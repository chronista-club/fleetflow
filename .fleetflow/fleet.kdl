project "fleetflow-services"

// === クラウドプロバイダー ===

provider "sakura-cloud" {
    zone "tk1a"
}

provider "cloudflare" {
}

// === サーバー ===

server "fleetflow-cp" {
    provider "sakura-cloud"
    plan "2core-4gb"
    disk-size 40
    os "debian"
    ssh-key "mito-mac.local"
    tags "fleetflow:cp"
    startup-script "fleetflow-docker-setup"
    // dns {
    //     hostname "console.fleetstage.cloud"
    // }
}

// === サービス定義 ===

// FleetFlow Control Plane デーモン
service "fleetflowd" {
    image "ghcr.io/chronista-club/fleetflowd:${FLEETFLOW_VERSION:-latest}"
    restart "unless-stopped"

    ports {
        port host=4510 container=4510
        port host=32080 container=32080
    }

    volumes {
        volume "/etc/fleetflow" "/etc/fleetflow" read-only=true
        volume "/var/run/docker.sock" "/var/run/docker.sock"
    }

    env {
        RUST_LOG "info"
        CLOUDFLARE_API_TOKEN "${CLOUDFLARE_API_TOKEN}"
        CLOUDFLARE_ZONE_ID "${CLOUDFLARE_ZONE_ID}"
    }
}

// SurrealDB サービス定義（Surreal Cloud 移行後は削除予定）
service "db" {
    image "surrealdb/surrealdb:v2"
    restart "unless-stopped"
    command "start --user root --pass root --bind [::]:8000 rocksdb:///data/database.db"

    volumes {
        volume "./data/surrealdb" "/data"
    }
}

// 開発環境 (Development)
// ポート範囲: 50000台
stage "dev" {
    service "db" {
        ports {
            port host=50001 container=8000
        }
        variables {
            DEBUG "true"
            LOG_LEVEL "debug"
        }
    }
}

// ライブ環境 (Live) + CP サーバー
stage "live" {
    server "fleetflow-cp"

    service "fleetflowd"

    service "db" {
        ports {
            port host=52001 container=8000
        }
        variables {
            DEBUG "false"
            LOG_LEVEL "warn"
        }
    }
}
