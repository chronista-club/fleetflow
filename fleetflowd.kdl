// FleetFlow Control Plane — ローカル開発設定
daemon {
    pid-file "/tmp/fleetflowd-dev.pid"
    log-level "info"
}

api {
    listen "[::1]:4510"
}

database {
    endpoint "mem://"
    namespace "fleetflow"
    database "control_plane"
}

web {
    listen "127.0.0.1:32080"
    auth0-client-id "owYGH1SIWbNJVufA9bWvJdoH1S3DVW2v"
}

auth {
    domain "anycreative.jp.auth0.com"
    audience "https://api.fleetflow.run"
}
