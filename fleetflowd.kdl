// FleetFlow Control Plane — ローカル開発設定
daemon {
    pid-file "/tmp/fleetflowd-dev.pid"
    log-level "info"
}

api {
    listen "[::1]:4510"
}

database {
    endpoint "mem://"
    namespace "fleetflow"
    database "control_plane"
}

web {
    listen "127.0.0.1:32080"
    auth0-client-id "${FLEETFLOW_AUTH0_CLIENT_ID}"
}

auth {
    domain "anycreative.jp.auth0.com"
    audience "https://api.fleetstage.cloud"
}

cloud {
    provider "sakura-cloud"
    zone "tk1a"
}
